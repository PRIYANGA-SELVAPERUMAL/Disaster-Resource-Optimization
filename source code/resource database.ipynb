"""
Resource Allocation Database Generator
=======================================
Generates the finalised realistic disaster resource database
matching resource_allocation_database_realistic.json exactly.

Sizing standards used:
  Ambulances  : ceil(injured / 30)         — 1 per 30 injured
  Buses       : ceil(displaced / 525)      — 1 per 525 displaced (wind zones)
  Boats       : ceil((injured+displaced)/59) — 1 per 59 affected (flood zones only)
  Beds/hosp   : max(40, ceil(bed_total / n_hospitals)) — min 40 beds per hospital
  Bed total   : ceil(amb_throughput * PPO_EFF / 9 * 1.15) where
                amb_throughput = ambulances * 2 * 16 * 0.875
  Shelter cap : ceil(displaced * 1.012) / n_shelters per shelter
  Severity    : 20% critical, 35% serious, 45% moderate (deterministic)
"""

import json
from math import ceil, radians, sin, cos, sqrt, atan2
import random

# ── Constants ─────────────────────────────────────────────────────────────────
AMB_CAPACITY   = 2       # patients per ambulance trip
AMB_TRIPS      = 16      # trips per ambulance per episode
AMB_EFFICIENCY = 0.875   # loading efficiency
PPO_EFFICIENCY = 0.95    # PPO routing efficiency
PATIENTS_PER_BED_PER_DAY = 9
BED_BUFFER     = 1.15    # 15% buffer
MIN_BEDS_PER_HOSPITAL = 40
SHELTER_BUFFER = 1.012   # 1.2% buffer

# Severity split (deterministic)
CRIT_RATIO = 0.20
SER_RATIO  = 0.35
# MOD_RATIO  = 0.45 (remainder)

# ── Zone input data (from WorldPop + risk model) ───────────────────────────────
# Each entry: zone_id, location, population, risk_score, risk_class,
#             disaster_type, people_clusters, n_hospitals, n_shelters
# people_clusters: list of {cluster_id, lat, lon, injured_total, uninjured_displaced}
# hospital/shelter lats/lons: pre-assigned from infrastructure mapping

