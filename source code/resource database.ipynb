# ── Helper functions ───────────────────────────────────────────────────────────

def severity_split(injured_total):
    """Deterministic 20/35/45 split — critical/serious/moderate."""
    critical = int(injured_total * CRIT_RATIO)
    serious  = int(injured_total * SER_RATIO)
    moderate = injured_total - critical - serious
    return {"critical": critical, "serious": serious, "moderate": moderate}


def calc_ambulances(total_injured):
    """1 ambulance per 30 injured."""
    return ceil(total_injured / 30)


def calc_beds(total_injured, n_hospitals):
    """
    Bed total = ceil(amb_throughput * PPO_eff / 9 * 1.15)
    Per hospital = max(40, ceil(total / n_hospitals))
    """
    amb = calc_ambulances(total_injured)
    amb_throughput   = amb * AMB_CAPACITY * AMB_TRIPS * AMB_EFFICIENCY
    expected_arrivals = amb_throughput * PPO_EFFICIENCY
    raw_beds = expected_arrivals / PATIENTS_PER_BED_PER_DAY * BED_BUFFER
    beds_per_hosp = max(MIN_BEDS_PER_HOSPITAL, ceil(raw_beds / n_hospitals))
    return beds_per_hosp  # same for each hospital


def calc_buses(total_displaced):
    """1 bus per 525 displaced."""
    return ceil(total_displaced / 525)


def calc_boats(total_injured, total_displaced):
    """1 boat per 59 (injured + displaced) — flood zones only."""
    return ceil((total_injured + total_displaced) / 59)


def calc_shelter_cap(total_displaced, n_shelters):
    """
    Total shelter cap = ceil(displaced * 1.012)
    Distributed evenly across shelters.
    """
    total_cap = ceil(total_displaced * SHELTER_BUFFER)
    base = total_cap // n_shelters
    remainder = total_cap - base * n_shelters
    # Distribute remainder across first shelters
    caps = [base + (1 if i < remainder else 0) for i in range(n_shelters)]
    return caps


# ── Main generation function ───────────────────────────────────────────────────

def generate_database(zone_input):
    db = {"zones": {}}

    for zid, inp in zone_input.items():
        is_flood = inp["disaster_type"] == "flood"
        n_hosp   = inp["n_hospitals"]
        n_shel   = inp["n_shelters"]

        # Totals
        total_inj = sum(c["injured"]   for c in inp["clusters"])
        total_dis = sum(c["displaced"] for c in inp["clusters"])

        # ── People clusters ──────────────────────────────────────────────────
        people_clusters = []
        for c in inp["clusters"]:
            sev = severity_split(c["injured"])
            people_clusters.append({
                "cluster_id":         c["id"],
                "location":           {"lat": c["lat"], "lon": c["lon"]},
                "injured_total":      c["injured"],
                "uninjured_displaced": c["displaced"],
                "severity":           sev,
                "severity_alive":     dict(sev),   # reset at episode start
                "dead_by_severity":   {"critical": 0, "serious": 0, "moderate": 0},
                "rescued":            0,
            })

        # ── Hospitals ────────────────────────────────────────────────────────
        beds_per_hosp = calc_beds(total_inj, n_hosp)
        hospitals = []
        for h in inp["hospital_locs"]:
            hospitals.append({
                "hospital_id":    h["id"],
                "location":       {"lat": h["lat"], "lon": h["lon"]},
                "total_beds":     beds_per_hosp,
                "available_beds": beds_per_hosp,
            })

        # ── Shelters ─────────────────────────────────────────────────────────
        shel_caps = calc_shelter_cap(total_dis, n_shel)
        shelters = []
        for i, s in enumerate(inp["shelter_locs"]):
            shelters.append({
                "shelter_id": s["id"],
                "location":   {"lat": s["lat"], "lon": s["lon"]},
                "capacity":   shel_caps[i],
                "occupied":   0,
            })

        # ── Transport resources ──────────────────────────────────────────────
        ambulances = calc_ambulances(total_inj)
        buses      = calc_buses(total_dis)
        transport_resources = {
            "ambulances":          ambulances,
            "ambulance_capacity":  AMB_CAPACITY,
            "buses":               buses,
            "bus_capacity":        50,
        }

        # ── Disaster resources (boats — flood only) ──────────────────────────
        disaster_resources = {}
        if is_flood:
            disaster_resources = {
                "boats":          calc_boats(total_inj, total_dis),
                "boat_capacity":  10,
            }

        # ── Assemble zone ────────────────────────────────────────────────────
        db["zones"][zid] = {
            "zone_id":            inp["zone_id"],
            "location":           inp["location"],
            "population":         inp["population"],
            "risk_score":         inp["risk_score"],
            "risk_class":         inp["risk_class"],
            "disaster_type":      inp["disaster_type"],
            "people_clusters":    people_clusters,
            "hospitals":          hospitals,
            "shelters":           shelters,
            "transport_resources": transport_resources,
            "disaster_resources":  disaster_resources,
        }

    return db


# ── Run ────────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    db = generate_database(ZONE_INPUT)

    output_path = "resource_allocation_database_realistic.json"
    with open(output_path, "w") as f:
        json.dump(db, f, indent=2)

    print(f"✅ Database generated → {output_path}\n")

    # Quick summary
    print(f"{'Zone':<5} {'Type':<7} {'Inj':>6} {'Dis':>6} {'Beds':>6} "
          f"{'ShelCap':>8} {'Amb':>5} {'Bus':>5} {'Boat':>5}")
    print("─" * 60)
    for zid, z in db["zones"].items():
        cls = z["people_clusters"]
        total_inj = sum(c["severity"]["critical"]+c["severity"]["serious"]+c["severity"]["moderate"] for c in cls)
        total_dis = sum(c["uninjured_displaced"] for c in cls)
        total_beds = sum(h["total_beds"] for h in z["hospitals"])
        total_shel = sum(s["capacity"] for s in z["shelters"])
        amb   = z["transport_resources"]["ambulances"]
        buses = z["transport_resources"]["buses"]
        boats = z.get("disaster_resources", {}).get("boats", 0)
        print(f"{zid:<5} {z['disaster_type']:<7} {total_inj:>6,} {total_dis:>6,} "
              f"{total_beds:>6,} {total_shel:>8,} {amb:>5,} {buses:>5,} {boats:>5,}")